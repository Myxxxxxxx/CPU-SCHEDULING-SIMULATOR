#include <iostream>
#include <climits>
using namespace std;

// Structure to store process details
struct Process {
    int id;
    int arrivalTime;
    int burstTime;
    int priority;
    int completionTime;
    int turnaroundTime;
    int waitingTime;
};

// Validate input
bool isValidInput(int time) {
    if (time < 0) {
        cout << "Error: Time cannot be negative!\n";
        return false;
    }
    return true;
}

// First Come First Served
void fcfs(Process p[], int n) {
    int currentTime = 0;
    float totalWT = 0, totalTAT = 0;

    cout << "\n--- FCFS Scheduling ---\n";
    cout << "Process\tAT\tBT\tCT\tTAT\tWT\n";
    for (int i = 0; i < n; i++) {
        if (currentTime < p[i].arrivalTime)
            currentTime = p[i].arrivalTime;

        p[i].completionTime = currentTime + p[i].burstTime;
        p[i].turnaroundTime = p[i].completionTime - p[i].arrivalTime;
        p[i].waitingTime = p[i].turnaroundTime - p[i].burstTime;

        totalWT += p[i].waitingTime;
        totalTAT += p[i].turnaroundTime;
        currentTime = p[i].completionTime;

        cout << "P" << p[i].id << "\t" << p[i].arrivalTime << "\t" << p[i].burstTime << "\t"
             << p[i].completionTime << "\t" << p[i].turnaroundTime << "\t" << p[i].waitingTime << "\n";
    }
    cout << "Average Waiting Time: " << totalWT / n << " ms\n";
    cout << "Average Turnaround Time: " << totalTAT / n << " ms\n";
}

// Shortest Job First
void sjf(Process p[], int n) {
    Process temp[10];
    for (int i = 0; i < n; i++) temp[i] = p[i];

    int completed = 0, currentTime = 0;
    float totalWT = 0, totalTAT = 0;
    bool visited[10] = {false};

    cout << "\n--- SJF Scheduling ---\n";
    cout << "Process\tAT\tBT\tCT\tTAT\tWT\n";
    while (completed < n) {
        int minBurst = INT_MAX;
        int index = -1;

        for (int i = 0; i < n; i++) {
            if (!visited[i] && temp[i].arrivalTime <= currentTime && temp[i].burstTime < minBurst) {
                minBurst = temp[i].burstTime;
                index = i;
            }
        }

        if (index == -1) {
            currentTime++;
            continue;
        }

        visited[index] = true;
        currentTime += temp[index].burstTime;
        temp[index].completionTime = currentTime;
        temp[index].turnaroundTime = temp[index].completionTime - temp[index].arrivalTime;
        temp[index].waitingTime = temp[index].turnaroundTime - temp[index].burstTime;

        totalWT += temp[index].waitingTime;
        totalTAT += temp[index].turnaroundTime;
        completed++;

        cout << "P" << temp[index].id << "\t" << temp[index].arrivalTime << "\t" << temp[index].burstTime << "\t"
             << temp[index].completionTime << "\t" << temp[index].turnaroundTime << "\t" << temp[index].waitingTime << "\n";
    }
    cout << "Average Waiting Time: " << totalWT / n << " ms\n";
    cout << "Average Turnaround Time: " << totalTAT / n << " ms\n";
    cout << "Recommended: SJF gives lowest average waiting time\n";
}

// Priority Scheduling
void priorityScheduling(Process p[], int n) {
    Process temp[10];
    for (int i = 0; i < n; i++) temp[i] = p[i];

    int completed = 0, currentTime = 0;
    float totalWT = 0, totalTAT = 0;
    bool visited[10] = {false};

    cout << "\n--- Priority Scheduling ---\n";
    cout << "Process\tAT\tBT\tPriority\tCT\tTAT\tWT\n";
    while (completed < n) {
        int highestPriority = INT_MAX;
        int index = -1;

        for (int i = 0; i < n; i++) {
            if (!visited[i] && temp[i].arrivalTime <= currentTime && temp[i].priority < highestPriority) {
                highestPriority = temp[i].priority;
                index = i;
            }
        }

        if (index == -1) {
            currentTime++;
            continue;
        }

        visited[index] = true;
        currentTime += temp[index].burstTime;
        temp[index].completionTime = currentTime;
        temp[index].turnaroundTime = temp[index].completionTime - temp[index].arrivalTime;
        temp[index].waitingTime = temp[index].turnaroundTime - temp[index].burstTime;

        totalWT += temp[index].waitingTime;
        totalTAT += temp[index].turnaroundTime;
        completed++;

        cout << "P" << temp[index].id << "\t" << temp[index].arrivalTime << "\t" << temp[index].burstTime << "\t"
             << temp[index].priority << "\t\t" << temp[index].completionTime << "\t" << temp[index].turnaroundTime << "\t" << temp[index].waitingTime << "\n";
    }
    cout << "Average Waiting Time: " << totalWT / n << " ms\n";
    cout << "Average Turnaround Time: " << totalTAT / n << " ms\n";
}

// Round Robin
void roundRobin(Process p[], int n, int timeQuantum) {
    int remBurst[10];
    int currentTime = 0, completed = 0;
    float totalWT = 0, totalTAT = 0;

    for (int i = 0; i < n; i++) remBurst[i] = p[i].burstTime;

    cout << "\n--- Round Robin (Quantum = " << timeQuantum << " ms) ---\n";
    cout << "Process\tAT\tBT\tCT\tTAT\tWT\n";
    while (completed < n) {
        bool done = true;
        for (int i = 0; i < n; i++) {
            if (remBurst[i] > 0 && p[i].arrivalTime <= currentTime) {
                done = false;
                if (remBurst[i] > timeQuantum) {
                    currentTime += timeQuantum;
                    remBurst[i] -= timeQuantum;
                } else {
                    currentTime += remBurst[i];
                    p[i].completionTime = currentTime;
                    remBurst[i] = 0;
                    completed++;
                }
            }
        }
        if (done) currentTime++;
    }

    for (int i = 0; i < n; i++) {
        p[i].turnaroundTime = p[i].completionTime - p[i].arrivalTime;
        p[i].waitingTime = p[i].turnaroundTime - p[i].burstTime;
        totalWT += p[i].waitingTime;
        totalTAT += p[i].turnaroundTime;

        cout << "P" << p[i].id << "\t" << p[i].arrivalTime << "\t" << p[i].burstTime << "\t"
             << p[i].completionTime << "\t" << p[i].turnaroundTime << "\t" << p[i].waitingTime << "\n";
    }
    cout << "Average Waiting Time: " << totalWT / n << " ms\n";
    cout << "Average Turnaround Time: " << totalTAT / n << " ms\n";
}

// Test Cases
void runTestCases() {
    cout << "\n=====================================\n";
    cout << "RUNNING TEST CASES\n";
    cout << "=====================================\n";

    // Normal Case
    cout << "\n--- Test 1: Different Arrival Times ---\n";
    Process t1[] = {{1,0,4,2}, {2,2,3,1}, {3,4,1,3}, {4,6,2,2}};
    sjf(t1, 4);

    // All arrive at 0
    cout << "\n--- Test 2: All Arrive at Time 0 ---\n";
    Process t2[] = {{1,0,5,1}, {2,0,2,2}, {3,0,7,3}, {4,0,3,4}};
    sjf(t2, 4);

    // One arrives late
    cout << "\n--- Test 3: One Process Arrives Very Late ---\n";
    Process t3[] = {{1,0,3,1}, {2,1,2,2}, {3,20,1,3}};
    sjf(t3, 3);

    // All burst times equal
    cout << "\n--- Test 4: All Burst Times Equal ---\n";
    Process t4[] = {{1,0,3,1}, {2,1,3,2}, {3,2,3,3}, {4,3,3,4}};
    sjf(t4, 4);

    // Invalid input
    cout << "\n--- Test 5: Invalid Input Check ---\n";
    isValidInput(-3);
    isValidInput(7);
}

// Main Program
int main() {
    Process processes[10];
    int n, choice, quantum;
    bool valid;

    cout << "=====================================\n";
    cout << "CPU SCHEDULING SIMULATOR\n";
    cout << "=====================================\n";

    do {
        cout << "\nMenu:\n";
        cout << "1. Enter Process Data\n";
        cout << "2. Run FCFS\n";
        cout << "3. Run SJF\n";
        cout << "4. Run Priority Scheduling\n";
        cout << "5. Run Round Robin\n";
        cout << "6. Run All Test Cases\n";
        cout << "7. Exit\n";
        cout << "Enter your choice: ";
        cin >> choice;

        switch (choice) {
            case 1:
                cout << "Enter number of processes (max 10): ";
                cin >> n;
                if (n < 1 || n > 10) {
                    cout << "Invalid number!\n";
                    break;
                }
                for (int i = 0; i < n; i++) {
                    cout << "\nProcess " << i+1 << ":\n";
                    processes[i].id = i+1;
                    do {
                        cout << "Arrival Time: ";
                        cin >> processes[i].arrivalTime;
                        valid = isValidInput(processes[i].arrivalTime);
                    } while (!valid);
                    do {
                        cout << "Burst Time: ";
                        cin >> processes[i].burstTime;
                        valid = isValidInput(processes[i].burstTime);
                    } while (!valid);
                    do {
                        cout << "Priority: ";
                        cin >> processes[i].priority;
                        valid = isValidInput(processes[i].priority);
                    } while (!valid);
                }
                break;

            case 2: fcfs(processes, n); break;
            case 3: sjf(processes, n); break;
            case 4: priorityScheduling(processes, n); break;
            case 5:
                cout << "Enter Time Quantum: ";
                cin >> quantum;
                if (quantum <= 0) cout << "Invalid quantum!\n";
                else roundRobin(processes, n, quantum);
                break;
            case 6: runTestCases(); break;
            case 7: break;
            default: cout << "Invalid choice!\n";
        }
    } while (choice != 7);

    return 0;
}
